<script>
// ── STATE ──────────────────────────────────────────────────────────────────
let state = {
  user: null,
  transactions: [],
  users: {}  // email -> {name, pass, transactions}
}

// ── CATEGORIES ─────────────────────────────────────────────────────────────
const CAT_MAP = {
  swiggy:'food', zomato:'food', pizza:'food', kfc:'food', mcdonalds:'food',
  grocery:'food', supermarket:'food', restaurant:'food', coffee:'food',
  bakery:'food', milk:'food', vegetables:'food', food:'food',
  uber:'transport', ola:'transport', rapido:'transport', metro:'transport',
  bus:'transport', petrol:'transport', fuel:'transport', cab:'transport',
  rent:'rent', house:'rent', pg:'rent', apartment:'rent',
  electricity:'utilities', water:'utilities', internet:'utilities',
  broadband:'utilities', mobile:'utilities', recharge:'utilities', gas:'utilities',
  netflix:'entertainment', spotify:'entertainment', amazon:'entertainment',
  movie:'entertainment', game:'entertainment', disney:'entertainment',
  salary:'salary', payroll:'salary', wages:'salary', credit:'salary',
  pharmacy:'medical', doctor:'medical', hospital:'medical', medicine:'medical',
  clinic:'medical', lab:'medical', health:'medical',
  amazon:'shopping', flipkart:'shopping', myntra:'shopping', clothing:'shopping',
  shoes:'shopping', electronics:'shopping', fashion:'shopping', order:'shopping',
  sip:'savings_deposit', mutual:'savings_deposit', fd:'savings_deposit',
  ppf:'savings_deposit', deposit:'savings_deposit', investment:'savings_deposit',
}

function categorize(desc) {
  const d = desc.toLowerCase()
  for (const [k, v] of Object.entries(CAT_MAP)) {
    if (d.includes(k)) return v
  }
  return 'other'
}

// ── AUTH ───────────────────────────────────────────────────────────────────
function switchAuthTab(tab) {
  document.querySelectorAll('.auth-tab').forEach((t,i) => {
    t.classList.toggle('active', (i===0&&tab==='login')||(i===1&&tab==='signup'))
  })
  document.getElementById('auth-login').style.display  = tab==='login'  ? '' : 'none'
  document.getElementById('auth-signup').style.display = tab==='signup' ? '' : 'none'
}

function handleLogin() {
  const email = document.getElementById('login-email').value.trim()
  const pass  = document.getElementById('login-pass').value
  if (!email||!pass) { toast('⚠️ Please fill all fields'); return }
  if (state.users[email]) {
    if (state.users[email].pass !== pass) { toast('❌ Wrong password'); return }
    loginAs(email, state.users[email].name)
  } else if (email==='demo@pocketsafe.app' && pass==='demo1234') {
    loginAs(email, 'Demo User', true)
  } else {
    toast('❌ No account found. Sign up first.')
  }
}

function handleSignup() {
  const name  = document.getElementById('signup-name').value.trim()
  const email = document.getElementById('signup-email').value.trim()
  const pass  = document.getElementById('signup-pass').value
  if (!name||!email||!pass) { toast('⚠️ Please fill all fields'); return }
  if (pass.length < 6) { toast('⚠️ Password too short'); return }
  if (state.users[email]) { toast('⚠️ Email already registered'); return }
  state.users[email] = { name, pass, transactions: [] }
  loginAs(email, name)
  toast('✅ Account created!')
}

function handleDemo() { loginAs('demo@pocketsafe.app', 'Demo User', true) }

function loginAs(email, name, isDemo=false) {
  state.user = { email, name }
  if (isDemo && !state.users[email]) {
    state.users[email] = { name, pass:'demo1234', transactions: getDemoTxns() }
  }
  state.transactions = state.users[email]?.transactions || []

  document.getElementById('auth-screen').style.display = 'none'
  document.getElementById('app').style.display = 'flex'

  document.getElementById('user-avatar').textContent = name[0].toUpperCase()
  document.getElementById('user-name-display').textContent = name
  document.getElementById('user-email-display').textContent = email

  // Set today's date in add form
  document.getElementById('f-date').value = new Date().toISOString().split('T')[0]
  document.getElementById('dash-date').textContent = new Date().toLocaleDateString('en-IN',{weekday:'long',year:'numeric',month:'long',day:'numeric'})

  refreshAll()
  nav('dashboard')
  toast('👋 Welcome back, '+name.split(' ')[0]+'!')
}

function handleLogout() {
  save()
  state.user = null
  state.transactions = []
  document.getElementById('app').style.display = 'none'
  document.getElementById('auth-screen').style.display = 'flex'
  document.getElementById('chat-window').innerHTML = '<div class="bubble ai">👋 Hi! I\'m your finance assistant. Ask me anything!</div>'
}

function save() {
  if (state.user) {
    state.users[state.user.email].transactions = state.transactions
  }
}

// ── NAVIGATION ─────────────────────────────────────────────────────────────
function nav(page) {
  ['dashboard','transactions','forecast','tips','chat'].forEach(p => {
    document.getElementById('page-'+p).style.display = p===page ? '' : 'none'
    document.getElementById('nav-'+p).classList.toggle('active', p===page)
  })
  if (page==='forecast') drawForecast()
}

// ── TRANSACTIONS ───────────────────────────────────────────────────────────
function addTx() {
  const desc   = document.getElementById('f-desc').value.trim()
  const amount = parseFloat(document.getElementById('f-amount').value)
  const account= document.getElementById('f-account').value
  const date   = document.getElementById('f-date').value
  if (!desc || isNaN(amount)) { toast('⚠️ Fill description and amount'); return }

  const tx = {
    id: Date.now(),
    description: desc,
    amount,
    category: categorize(desc),
    account,
    date: date || new Date().toISOString().split('T')[0]
  }
  state.transactions.unshift(tx)
  save()
  document.getElementById('f-desc').value = ''
  document.getElementById('f-amount').value = ''
  refreshAll()
  toast('✅ Transaction added!')
}

function deleteTx(id) {
  if (!confirm('Delete this transaction?')) return
  state.transactions = state.transactions.filter(t => t.id !== id)
  save()
  refreshAll()
  toast('🗑️ Deleted')
}

// ── REFRESH ─────────────────────────────────────────────────────────────────
function refreshAll() {
  const txns = state.transactions
  const income   = txns.filter(t=>t.amount>0).reduce((s,t)=>s+t.amount,0)
  const expense  = txns.filter(t=>t.amount<0).reduce((s,t)=>s+Math.abs(t.amount),0)
  const savings  = income - expense
  const rate     = income>0 ? (savings/income*100).toFixed(1) : 0

  // Stats
  document.getElementById('stat-income').textContent  = fmt(income)
  document.getElementById('stat-expense').textContent = fmt(expense)
  document.getElementById('stat-savings').textContent = fmt(savings)
  document.getElementById('stat-rate').textContent    = rate+'%'
  document.getElementById('stat-income-count').textContent  = txns.filter(t=>t.amount>0).length+' transactions'
  document.getElementById('stat-expense-count').textContent = txns.filter(t=>t.amount<0).length+' transactions'
  document.getElementById('stat-rate-label').textContent = rate>=20 ? '✓ On track!' : 'target: 20%'

  // Category bars
  const catSpend = {}
  txns.filter(t=>t.amount<0).forEach(t=>{
    const c=t.category||'other'; catSpend[c]=(catSpend[c]||0)+Math.abs(t.amount)
  })
  const maxCat = Math.max(...Object.values(catSpend), 1)
  const catEl  = document.getElementById('cat-list')
  if (!Object.keys(catSpend).length) {
    catEl.innerHTML = '<div class="empty">Add transactions to see breakdown</div>'
  } else {
    catEl.innerHTML = Object.entries(catSpend)
      .sort((a,b)=>b[1]-a[1]).slice(0,7)
      .map(([cat,val])=>`
        <div class="cat-row">
          <div class="cat-name">${cat}</div>
          <div class="cat-bar-bg"><div class="cat-bar" style="width:${(val/maxCat*100).toFixed(1)}%"></div></div>
          <div class="cat-val">${fmt(val)}</div>
        </div>`).join('')
  }

  // Recent
  const recEl = document.getElementById('recent-list')
  if (!txns.length) {
    recEl.innerHTML = '<div class="empty">No transactions yet</div>'
  } else {
    recEl.innerHTML = txns.slice(0,5).map(t=>`
      <div style="display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid rgba(42,42,61,.5)">
        <div>
          <div style="font-size:13px;color:var(--text)">${t.description}</div>
          <div style="font-size:11px;color:var(--text3);margin-top:2px">${t.category} · ${t.date}</div>
        </div>
        <div class="${t.amount>0?'amount-pos':'amount-neg'}">${t.amount>0?'+':''}${fmt(Math.abs(t.amount))}</div>
      </div>`).join('')
  }

  // TX table
  const tbody = document.getElementById('tx-body')
  if (!txns.length) {
    tbody.innerHTML = '<tr><td colspan="6" class="empty">No transactions yet</td></tr>'
  } else {
    tbody.innerHTML = txns.map(t=>`
      <tr>
        <td style="color:var(--text3);font-family:var(--mono);font-size:12px">${t.date}</td>
        <td style="color:var(--text)">${t.description}</td>
        <td><span class="badge">${t.category}</span></td>
        <td style="color:var(--text3)">${t.account}</td>
        <td class="${t.amount>0?'amount-pos':'amount-neg'}">${t.amount>0?'+':''}${fmt(Math.abs(t.amount))}</td>
        <td><button class="del-btn" onclick="deleteTx(${t.id})">✕</button></td>
      </tr>`).join('')
  }

  // Tips
  buildTips(income, expense, catSpend)
}

function fmt(n) {
  return '₹'+Math.round(n).toLocaleString('en-IN')
}

// ── TIPS ───────────────────────────────────────────────────────────────────
function buildTips(income, expense, catSpend) {
  const el = document.getElementById('tips-list')
  if (!income && !expense) { el.innerHTML='<div class="empty">Add transactions to get insights</div>'; return }

  const tips = []
  const savRate = income > 0 ? (income-expense)/income : 0

  if (savRate >= 0.2) tips.push({sev:'good', icon:'🎉', msg:`Great savings rate of ${(savRate*100).toFixed(1)}%! You're above the 20% target.`})
  else tips.push({sev:'critical', icon:'⚠️', msg:`Savings rate is ${(savRate*100).toFixed(1)}%. Try to save at least 20% of income. Consider automating transfers on payday.`})

  if (income>0 && (catSpend.food||0)/income > 0.15)
    tips.push({sev:'warning', icon:'🍔', msg:`Food spending is ${((catSpend.food/income)*100).toFixed(1)}% of income (>15%). Try meal-prepping or cooking at home.`})

  if (income>0 && (catSpend.entertainment||0)/income > 0.10)
    tips.push({sev:'warning', icon:'🎬', msg:`Entertainment is ${((catSpend.entertainment/income)*100).toFixed(1)}% of income. Look for free alternatives.`})

  if (income>0 && (catSpend.shopping||0)/income > 0.20)
    tips.push({sev:'warning', icon:'🛍️', msg:`Shopping at ${((catSpend.shopping/income)*100).toFixed(1)}% of income. Try the 48-hour rule before non-essential purchases.`})

  if ((catSpend.savings_deposit||0) === 0 && income > 0)
    tips.push({sev:'info', icon:'📦', msg:`No investment transactions found. Consider starting a SIP or recurring deposit.`})

  const topCat = Object.entries(catSpend).sort((a,b)=>b[1]-a[1])[0]
  if (topCat) tips.push({sev:'info', icon:'📊', msg:`Your biggest expense category is "${topCat[0]}" at ${fmt(topCat[1])}.`})

  el.innerHTML = tips.map(t=>`
    <div class="tip ${t.sev}">
      <div class="tip-icon">${t.icon}</div>
      <div>${t.msg}</div>
    </div>`).join('')
}

// ── FORECAST ───────────────────────────────────────────────────────────────
function drawForecast() {
  const canvas = document.getElementById('forecast-canvas')
  const ctx = canvas.getContext('2d')
  canvas.width  = canvas.offsetWidth * window.devicePixelRatio
  canvas.height = 220 * window.devicePixelRatio
  ctx.scale(window.devicePixelRatio, window.devicePixelRatio)
  const W = canvas.offsetWidth, H = 220

  const txns = state.transactions
  const dailyIn  = txns.filter(t=>t.amount>0).reduce((s,t)=>s+t.amount,0) / Math.max(txns.length,1)
  const dailyOut = txns.filter(t=>t.amount<0).reduce((s,t)=>s+Math.abs(t.amount),0) / Math.max(txns.length,1)

  const days = 15
  const data = Array.from({length:days},(_,i)=>{
    const jitter = 0.8 + Math.random()*0.4
    return { inflow: dailyIn*jitter*days/15, outflow: dailyOut*jitter*days/15, day: i+1 }
  })

  const maxY = Math.max(...data.map(d=>Math.max(d.inflow,d.outflow)), 1)
  const pad = {top:20, right:20, bottom:30, left:50}
  const chartW = W - pad.left - pad.right
  const chartH = H - pad.top  - pad.bottom

  ctx.clearRect(0,0,W,H)

  function scaleX(i) { return pad.left + (i/(days-1))*chartW }
  function scaleY(v) { return pad.top + chartH - (v/maxY)*chartH }

  function drawLine(arr, key, color) {
    ctx.beginPath()
    arr.forEach((d,i) => { i===0 ? ctx.moveTo(scaleX(i),scaleY(d[key])) : ctx.lineTo(scaleX(i),scaleY(d[key])) })
    ctx.strokeStyle = color; ctx.lineWidth = 2.5; ctx.stroke()
    // fill
    ctx.beginPath()
    arr.forEach((d,i) => { i===0 ? ctx.moveTo(scaleX(i),scaleY(d[key])) : ctx.lineTo(scaleX(i),scaleY(d[key])) })
    ctx.lineTo(scaleX(arr.length-1), scaleY(0))
    ctx.lineTo(scaleX(0), scaleY(0))
    ctx.closePath()
    const grad = ctx.createLinearGradient(0,pad.top,0,H-pad.bottom)
    grad.addColorStop(0, color+'44'); grad.addColorStop(1, color+'00')
    ctx.fillStyle = grad; ctx.fill()
  }

  // Grid lines
  ctx.strokeStyle='rgba(42,42,61,0.6)'; ctx.lineWidth=1
  for(let i=0;i<=4;i++){
    const y=pad.top+i*(chartH/4)
    ctx.beginPath(); ctx.moveTo(pad.left,y); ctx.lineTo(W-pad.right,y); ctx.stroke()
    ctx.fillStyle='#555577'; ctx.font='11px DM Mono,monospace'; ctx.textAlign='right'
    ctx.fillText('₹'+Math.round(maxY*(1-i/4)/1000)+'k', pad.left-6, y+4)
  }

  // Day labels
  ctx.fillStyle='#555577'; ctx.font='10px DM Mono,monospace'; ctx.textAlign='center'
  data.forEach((_,i)=>{ if(i%3===0) ctx.fillText('d'+(i+1), scaleX(i), H-8) })

  drawLine(data,'inflow','#00e5a0')
  drawLine(data,'outflow','#ff4d6d')

  // Legend
  ctx.fillStyle='#00e5a0'; ctx.fillRect(W-90,8,14,3)
  ctx.fillStyle='#eeeeff'; ctx.font='11px Syne,sans-serif'; ctx.textAlign='left'; ctx.fillText('Inflow',W-72,13)
  ctx.fillStyle='#ff4d6d'; ctx.fillRect(W-90,20,14,3)
  ctx.fillStyle='#eeeeff'; ctx.fillText('Outflow',W-72,25)

  const projIn  = data.reduce((s,d)=>s+d.inflow,0)
  const projOut = data.reduce((s,d)=>s+d.outflow,0)
  document.getElementById('proj-income').textContent  = fmt(projIn)
  document.getElementById('proj-expense').textContent = fmt(projOut)
}

// ── CHAT ───────────────────────────────────────────────────────────────────
const API_KEY_PLACEHOLDER = '' // Set your key here or connect backend

async function sendChat() {
  const input = document.getElementById('chat-input')
  const msg = input.value.trim()
  if (!msg) return
  input.value = ''

  const win = document.getElementById('chat-window')
  win.innerHTML += `<div class="bubble user">${msg}</div>`

  const typing = document.createElement('div')
  typing.className = 'bubble ai typing'
  typing.textContent = 'Thinking...'
  win.appendChild(typing)
  win.scrollTop = win.scrollHeight

  const txns = state.transactions
  const income  = txns.filter(t=>t.amount>0).reduce((s,t)=>s+t.amount,0)
  const expense = txns.filter(t=>t.amount<0).reduce((s,t)=>s+Math.abs(t.amount),0)
  const catSpend = {}
  txns.filter(t=>t.amount<0).forEach(t=>{ const c=t.category||'other'; catSpend[c]=(catSpend[c]||0)+Math.abs(t.amount) })

  const context = `You are a personal finance assistant. The user's financial data:
Total income: ₹${Math.round(income)}
Total expenses: ₹${Math.round(expense)}
Net savings: ₹${Math.round(income-expense)}
Savings rate: ${income>0?((income-expense)/income*100).toFixed(1):0}%
Spending by category: ${JSON.stringify(Object.fromEntries(Object.entries(catSpend).map(([k,v])=>[k,Math.round(v)])))}
Recent transactions (last 10):
${txns.slice(0,10).map(t=>`- ${t.date} | ${t.description} | ₹${t.amount} | ${t.category}`).join('\n')}
Answer concisely. Use ₹ for amounts.`

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': API_KEY_PLACEHOLDER,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 400,
        system: context,
        messages: [{ role: 'user', content: msg }]
      })
    })
    const data = await res.json()
    const answer = data?.content?.[0]?.text || smartReply(msg, income, expense, catSpend)
    typing.textContent = answer
  } catch {
    typing.textContent = smartReply(msg, income, expense, catSpend)
  }
  typing.classList.remove('typing')
  win.scrollTop = win.scrollHeight
}

function smartReply(msg, income, expense, catSpend) {
  const m = msg.toLowerCase()
  if (m.includes('income') || m.includes('earn')) return `Your total income is ₹${Math.round(income).toLocaleString('en-IN')}.`
  if (m.includes('spend') || m.includes('expense')) return `Your total expenses are ₹${Math.round(expense).toLocaleString('en-IN')}.`
  if (m.includes('sav')) {
    const r = income>0?((income-expense)/income*100).toFixed(1):0
    return `Your savings rate is ${r}%. ${r>=20?'Great job — above the 20% target!':'Try to reach the 20% target.'}`
  }
  if (m.includes('food')) return `Food spending: ₹${Math.round(catSpend.food||0).toLocaleString('en-IN')}.`
  if (m.includes('transport')) return `Transport spending: ₹${Math.round(catSpend.transport||0).toLocaleString('en-IN')}.`
  const top = Object.entries(catSpend).sort((a,b)=>b[1]-a[1])[0]
  if (top) return `Your top spending category is "${top[0]}" at ₹${Math.round(top[1]).toLocaleString('en-IN')}.`
  return `I can see your transaction history. Ask me about income, expenses, savings rate, or specific categories!`
}

